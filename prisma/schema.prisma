// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
} 

model User {
  id            String  @id @default(cuid())
  name          String?
  email         String  @unique
  emailVerified DateTime?
  image         String?
  password      String? // for credentials login

  verificationToken      String?
  verificationTokenExpiry DateTime?

  resetToken             String?
  resetTokenExpiry       DateTime?

  accounts Account[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model KnowledgeFile {
  id        String   @id @default(cuid())
  name      String
  path      String
  size      Int
  type      String

  workspaceId String

  status    String   @default("processing") // processing | ready | failed

  createdAt DateTime @default(now())

  chunks Chunk[]

  chatbotLinks ChatbotKnowledge[]

  @@index([workspaceId])
}

model Guardrail {
  id        String   @id @default(cuid())
  name      String
  description   String?

  workspaceId String

  createdAt DateTime @default(now())
  chatbotLinks ChatbotGuardrail[]
}

model Chunk {
  id        String   @id @default(cuid())

  content   String

  embedding Unsupported("vector") // pgvector

  workspaceId String

  fileId    String
  file      KnowledgeFile @relation(fields: [fileId], references: [id])

  metadata  Json?

  createdAt DateTime @default(now())

  @@index([workspaceId])
}

model ChatbotKnowledge {
  id         String @id @default(cuid())

  chatbotId  String
  fileId     String

  chatbot    Chatbot       @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  file       KnowledgeFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([chatbotId, fileId])
}

model LauncherConfig {
  id              String   @id @default(cuid())

  backgroundColor String?  @default("#667eea")
  borderRadius    Int?     @default(50)
  padding         Int?     @default(8)

  icon            String?  @default("message")
  logoUrl         String?

  size            Int?     @default(56)

  configurationId String   @unique
  configuration   Configuration @relation(fields: [configurationId], references: [id])
}

model Configuration {
  id              String   @id @default(cuid())

  systemPrompt    String?
  status          String   @default("draft")

  backgroundColor String?  @default("#ffffff")
  gradient        String?  @default("linear-gradient(135deg, #667eea 0%, #764ba2 100%)")
  gradientFrom    String?  @default("#667eea")
  gradientTo      String?  @default("#764ba2")

  textColor       String?  @default("#1a1a2e")

  borderRadius    Int?    @default(16)
  fontFamily      String? @default("inter")

  logoUrl         String?

  position        String? @default("bottom-right")

  accentColor     String? @default("#667eea")
  headerColor     String? @default("#667eea")

  chatbot         Chatbot?

  launcher        LauncherConfig?

  createdAt       DateTime @default(now())
}

model Chatbot {
  id            String   @id @default(cuid())
  name          String
  description   String?
  role          String
  systemPrompt  String?
  tone          String  @default("professional")
  enableMemory  Boolean @default(false)

  workspaceId   String

  provider      String
  model         String
  apiKey        String?

  configurationId String? @unique
  configuration   Configuration? @relation(fields: [configurationId], references: [id])

  knowledgeLinks ChatbotKnowledge[]
  guardrailLinks ChatbotGuardrail[]

  createdAt     DateTime @default(now())
}

model ChatbotGuardrail {
  id          String   @id @default(cuid())

  chatbotId   String
  guardrailId String

  chatbot     Chatbot  @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  guardrail   Guardrail @relation(fields: [guardrailId], references: [id], onDelete: Cascade)

  @@unique([chatbotId, guardrailId])
}